              ]
            },
            {
              "name": "Adminer",
              "patterns": ["<title>\\s*Adminer(?:\\s*</title>|\\s+-)", "(?:^|/)adminer(?:-[0-9.]+)?\\.php(?:[?#\\s]|$)"]
            },
            {
              "name": "pgAdmin",
              "patterns": ["<title>\\s*pgAdmin(?:\\s*</title>|\\s+-)", "(?:^|/)static/js/generated/(?:app|vendor|pgadmin)[^\\s\"'<>]*"]
