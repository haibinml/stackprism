                "virtual-server-theme[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"
              ]
            },
            {
              "name": "VestaCP",
              "patterns": [
                "(?:^|\\n)(?:VestaCP|Vesta Control Panel)(?:\\s*(?:Login|登录)|\\s*$)",
                "vesta(?:cp)?[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"
              ]
            },
            {
              "name": "Froxlor",
              "patterns": [
                "(?:^|\\n)Froxlor(?:\\s*(?:Server Management Panel|Login|登录)|\\s*$)",
                "froxlor[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"
