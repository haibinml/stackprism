            {
              "name": "Tiny File Manager",
              "kind": "文件管理面板",
              "patterns": [
                "(?:^|\\n)Tiny File Manager(?:\\s*(?:Login|登录)|\\s*$)",
                "tinyfilemanager[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"
              ]
            }
          ]
        }
      ]
    },
    "websitePrograms": {
      "defaults": {
        "category": "网站程序",
        "confidence": "高",
        "matchType": "regex"
      },
      "rules": [
        {
          "defaults": {
            "kind": "数据库 / 数据平台管理面板"
          },
          "rules": [
            {
              "name": "phpMyAdmin",
              "patterns": [
                "<title>\\s*phpMyAdmin(?:\\s*</title>|\\s+-)",
