            {
              "name": "Home Assistant",
              "patterns": [
                "(?:^|\\n)Home Assistant(?:\\s*(?:Login|登录|控制台)|\\s*$)",
                "(?:^|/)static/(?:frontend_latest|frontend_es5)(?:/|[?#]|$)"
              ]
            },
            {
              "name": "Frigate NVR",
              "patterns": [
                "(?:^|\\n)Frigate(?:\\s*(?:NVR|Login|Dashboard|登录|控制台)|\\s*$)",
