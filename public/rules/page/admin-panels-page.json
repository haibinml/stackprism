            },
            {
              "name": "File Browser",
              "kind": "文件管理面板",
              "patterns": [
                "(?:^|\\n)File Browser(?:\\s*(?:Login|登录|控制台)|\\s*$)",
                "filebrowser[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"
