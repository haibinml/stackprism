{
  "page": {
    "frontendExtra": [
      {
        "defaults": {
          "category": "前端库",
          "confidence": "中",
          "resourceOnly": true
        },
        "rules": [
          {
            "name": "Autosize",
            "patterns": ["(?:^|/)autosize(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "clipboard.js",
            "patterns": ["(?:^|/)clipboard(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "Flickity",
            "patterns": ["(?:^|/)flickity(?:\\.pkgd)?(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "imagesLoaded",
            "patterns": ["(?:^|/)imagesloaded(?:\\.pkgd)?(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "Packery",
            "patterns": ["(?:^|/)packery(?:\\.pkgd)?(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "QRious",
            "patterns": ["(?:^|/)qrious(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "qs",
            "patterns": ["(?:^|/)qs(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "Sticky Sidebar",
            "patterns": ["(?:^|/)sticky-sidebar(?:\\.min)?\\.js(?:[?#].*)?$"]
          },
          {
            "name": "Vuex",
            "resourceHints": ["vuex"],
            "patterns": ["(?:^|/)vuex(?:\\.(?:global|esm-browser|cjs|runtime))?(?:\\.prod)?(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)"],
            "globals": ["Vuex"]
          },
          {
            "name": "Vue ScrollTo",
            "patterns": ["(?:^|/)vue-scrollto(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)"]
          },
          {
            "name": "LazyLoad",
            "patterns": ["(?:^|/)(?:lazyload|lazy-load|vanilla-lazyload)(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)"]
          },
          {
            "name": "Layer.js",
            "patterns": ["(?:^|/)layer(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)"]
          },
          {
            "name": "jQuery UI",
            "patterns": [
              "(?:^|/)jquery-ui(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)",
              "(?:^|/)jquery\\.ui(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)"
            ]
          },
          {
            "name": "jQuery cxCalendar",
            "patterns": ["(?:^|/)jquery\\.cxcalendar(?:\\.min)?\\.js(?:[?#][^\\s\"'<>]*)?(?:[\"'<>\\s]|$)"]
          },
          {
            "name": "Zooming",
            "patterns": ["(?:^|/)zooming(?:\\.min)?\\.js(?:[?#].*)?$"]
          }
        ]
      }
    ]
  }
}
