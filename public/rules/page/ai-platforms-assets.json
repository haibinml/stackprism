              "name": "Langflow",
              "patterns": ["<title>\\s*Langflow(?:\\s*</title>|\\s+-)", "langflow[^\\s\"'<>]*\\.(?:js|css|svg|png|webp)(?:\\?|$)"]
            },
            {
