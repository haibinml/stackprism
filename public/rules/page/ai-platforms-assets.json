            {
              "name": "Flowise",
              "patterns": ["<title>\\s*Flowise(?:\\s*</title>|\\s+-)", "flowise[^\\s\"'<>]*\\.(?:js|css|svg|png|webp)(?:\\?|$)"]
            },
