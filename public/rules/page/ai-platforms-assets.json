              ]
            },
            {
              "name": "LibreChat",
              "patterns": ["<title>\\s*LibreChat(?:\\s*</title>|\\s+-)", "librechat[^\\s\"'<>]*\\.(?:js|css|svg|png|webp)(?:\\?|$)"]
            },
            {
