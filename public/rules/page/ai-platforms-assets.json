            {
              "name": "Rasa",
              "confidence": "中",
              "patterns": ["(?:^|[\\/._-])rasa-webchat[^\\s\"'<>]*\\.(?:js|css)(?:\\?|$)", "(?:^|/)rasa(?:/|[?#]|$)"]
