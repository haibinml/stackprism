              "resourceHints": ["oathkeeper", "ory-oathkeeper"],
              "patterns": ["(?:ory-)?oathkeeper[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"]
            },
            {
              "name": "SuperTokens",
              "kind": "身份认证 / 会话管理",
              "resourceHints": ["supertokens"],
              "patterns": ["supertokens[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"]
