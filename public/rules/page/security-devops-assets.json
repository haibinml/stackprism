              "resourceHints": ["ory-kratos", "kratos"],
              "patterns": ["ory-kratos[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)", "kratos-selfservice[^\\s\"'<>]*\\.(?:js|css)(?:\\?|$)"]
