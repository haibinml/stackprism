              "resourceHints": ["hanko"],
              "patterns": ["hanko[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"]
            }
          ]
        },
        {
          "name": "Dex",
          "kind": "身份认证 / OIDC",
          "confidence": "中",
          "resourceHints": ["/dex/", "dexidp"],
          "patterns": ["(?:^|/)dex/(?:static|theme)/(?:css|js|img)(?:/|[?#]|$)", "dexidp[^\\s\"'<>]*\\.(?:js|css|svg|png)(?:\\?|$)"]
        }
