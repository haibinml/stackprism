{
  "page": {
    "websitePrograms": [
      {
        "name": "WordPress",
        "kind": "CMS / 博客",
        "confidence": "高",
        "patterns": [
          "/wp-content/",
          "/wp-includes/",
          "wp-emoji-release",
          "wp-json"
        ],
        "globals": [
          "wp"
        ]
      },
      {
        "name": "WooCommerce",
        "kind": "电商插件",
        "confidence": "高",
        "patterns": [
          "woocommerce",
          "wc-cart-fragments",
          "wp-content/plugins/woocommerce"
        ]
      },
      {
        "name": "Drupal",
        "kind": "CMS",
        "confidence": "高",
        "patterns": [
          "drupal-settings-json",
          "/sites/default/files",
          "drupal\\."
        ],
        "globals": [
          "Drupal"
        ]
      },
      {
        "name": "Joomla",
        "kind": "CMS",
        "patterns": [
          "com_content",
          "/media/system/js/",
          "joomla"
        ]
      },
      {
        "name": "Magento / Adobe Commerce",
        "kind": "电商系统",
        "patterns": [
          "Magento_",
          "(?:^|/)static/(?:version\\d+/)?frontend/",
          "(?:^|/)pub/static/frontend/",
          "(?:^|/)frontend/[^\\s\"'<>?#]+/[^\\s\"'<>?#]+/(?:Magento_|mage/)",
          "requirejs-config\\.js.*(?:Magento_|mage)"
        ],
        "globals": [
          "Magento"
        ]
      },
      {
        "name": "Shopify",
        "kind": "SaaS 电商",
        "patterns": [
          "cdn.shopify.com",
          "shopify-section",
          "myshopify.com"
        ],
        "globals": [
          "Shopify"
        ]
      },
      {
        "name": "OpenCart",
        "kind": "电商系统",
        "patterns": [
          "catalog/view/theme",
          "index.php\\?route=",
          "opencart"
        ]
      },
      {
        "name": "PrestaShop",
        "kind": "电商系统",
        "patterns": [
          "prestashop",
          "/modules/ps_",
          "var prestashop"
        ]
      },
      {
        "name": "Shopware",
        "kind": "电商系统",
        "patterns": [
          "shopware",
          "widgets/emotion",
          "storefront/js"
        ]
      },
      {
        "name": "BigCommerce",
        "kind": "SaaS 电商",
        "patterns": [
          "bigcommerce",
          "cdn11.bigcommerce.com",
          "stencil-utils"
        ]
      },
      {
        "name": "Salesforce Commerce Cloud",
        "kind": "电商系统",
        "patterns": [
          "demandware",
          "salesforce commerce cloud",
          "/on/demandware.static/"
        ]
      },
      {
        "name": "Discuz!",
        "kind": "论坛",
        "patterns": [
          "discuz",
          "static/image/common",
          "forum.php",
          "portal.php"
        ]
      },
      {
        "name": "phpBB",
        "kind": "论坛",
        "patterns": [
          "phpbb",
          "styles/prosilver",
          "viewtopic.php"
        ]
      },
      {
        "name": "vBulletin",
        "kind": "论坛",
        "patterns": [
          "vbulletin",
          "clientscript/vbulletin",
          "showthread.php"
        ]
      },
      {
        "name": "XenForo",
        "kind": "论坛",
        "patterns": [
          "xenforo",
          "data-template=",
          "js/xf/"
        ]
      },
      {
        "name": "Flarum",
        "kind": "论坛",
        "patterns": [
          "flarum",
          "flarum.core",
          "assets/forum-"
        ]
      },
      {
        "name": "Discourse",
        "kind": "论坛 / 社区",
        "patterns": [
          "discourse",
          "__DISCOURSE",
          "/assets/discourse-"
        ],
        "globals": [
          "Discourse"
        ]
      },
      {
        "name": "MediaWiki",
        "kind": "Wiki",
        "patterns": [
          "mediawiki",
          "mw.config",
          "load.php\\?modules="
        ],
        "globals": [
          "mw"
        ]
      },
      {
        "name": "Confluence",
        "kind": "知识库",
        "patterns": [
          "confluence",
          "atlassian",
          "/s/en_GB/"
        ]
      },
      {
        "name": "Moodle",
        "kind": "学习管理系统",
        "patterns": [
          "moodle",
          "moodledata",
          "theme/yui_combo.php"
        ]
      },
      {
        "name": "Ghost",
        "kind": "博客",
        "patterns": [
          "ghost",
          "/ghost/api/",
          "ghost-sdk"
        ]
      },
      {
        "name": "Typecho",
        "kind": "博客",
        "patterns": [
          "typecho",
          "usr/themes",
          "usr/plugins"
        ]
      },
      {
        "name": "Z-BlogPHP",
        "kind": "博客",
        "patterns": [
          "zblogphp",
          "zb_users",
          "zb_system"
        ]
      },
      {
        "name": "DedeCMS",
        "kind": "CMS",
        "patterns": [
          "dedecms",
          "/templets/",
          "/plus/"
        ]
      },
      {
        "name": "PHPCMS",
        "kind": "CMS",
        "patterns": [
          "phpcms",
          "/statics/js/",
          "content=\"phpcms"
        ]
      },
      {
        "name": "EmpireCMS",
        "kind": "CMS",
        "patterns": [
          "empirecms",
          "/e/data/",
          "/e/public/"
        ]
      },
      {
        "name": "Craft CMS",
        "kind": "CMS",
        "patterns": [
          "craftcms",
          "craft\\.csrfTokenName",
          "CRAFT_CSRF_TOKEN"
        ]
      },
      {
        "name": "Umbraco",
        "kind": ".NET CMS",
        "patterns": [
          "umbraco",
          "/umbraco/"
        ]
      },
      {
        "name": "Strapi",
        "kind": "Headless CMS",
        "patterns": [
          "strapi",
          "strapi\\.io",
          "strapi-admin",
          "powered by strapi",
          "__strapi"
        ]
      },
      {
        "name": "Directus",
        "kind": "Headless CMS",
        "patterns": [
          "directus",
          "directus.io"
        ]
      },
      {
        "name": "Hexo",
        "kind": "静态博客",
        "patterns": [
          "hexo",
          "hexo-generator",
          "hexo-theme"
        ]
      },
      {
        "name": "Hugo",
        "kind": "静态站点生成器",
        "patterns": [
          "hugo",
          "generator\" content=\"hugo"
        ]
      },
      {
        "name": "Jekyll",
        "kind": "静态站点生成器",
        "patterns": [
          "jekyll",
          "generator\" content=\"jekyll"
        ]
      },
      {
        "name": "Docusaurus",
        "kind": "文档站点",
        "patterns": [
          "docusaurus",
          "__docusaurus",
          "/assets/js/webpack-runtime"
        ]
      },
      {
        "name": "VitePress",
        "kind": "文档站点",
        "patterns": [
          "vitepress",
          "VPContent",
          "/assets/chunks/"
        ]
      },
      {
        "name": "VuePress",
        "kind": "文档站点",
        "patterns": [
          "vuepress",
          "__VUEPRESS__"
        ]
      },
      {
        "name": "Docsify",
        "kind": "文档站点",
        "patterns": [
          "docsify",
          "window.$docsify"
        ],
        "globals": [
          "$docsify"
        ]
      },
      {
        "name": "GitBook",
        "kind": "文档站点",
        "patterns": [
          "gitbook",
          "gitbook.page.hasChanged"
        ]
      },
      {
        "name": "MkDocs",
        "kind": "文档站点",
        "patterns": [
          "mkdocs",
          "mkdocs_page_name",
          "material for mkdocs"
        ]
      },
      {
        "name": "ECShop",
        "kind": "电商系统",
        "patterns": [
          "ecshop",
          "themes/default/images/ecshop",
          "flow.php\\?step=cart",
          "ECSHOP"
        ]
      },
      {
        "name": "ShopXO",
        "kind": "电商系统",
        "patterns": [
          "shopxo",
          "public/static/index",
          "shopxo.net"
        ]
      },
      {
        "name": "Niushop",
        "kind": "电商系统",
        "patterns": [
          "niushop",
          "niucloud",
          "addon/shop",
          "牛之云"
        ]
      },
      {
        "name": "Youzan / 有赞",
        "kind": "SaaS 电商",
        "patterns": [
          "youzan.com",
          "koudaitong.com",
          "b.yzcdn.cn",
          "有赞"
        ]
      },
      {
        "name": "Weimob / 微盟",
        "kind": "SaaS 电商",
        "patterns": [
          "weimob.com",
          "weimobdc.com",
          "微盟"
        ]
      },
      {
        "name": "WShop / 微店",
        "kind": "SaaS 电商",
        "patterns": [
          "weidian.com",
          "vdian.com",
          "微店"
        ]
      },
      {
        "name": "Mabang ERP / 店铺系统",
        "kind": "电商系统",
        "patterns": [
          "mabangerp",
          "mabang",
          "马帮"
        ]
      }
    ]
  }
}
